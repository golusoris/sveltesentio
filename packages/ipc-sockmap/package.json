{
  "name": "@sveltesentio/ipc-sockmap",
  "version": "0.0.1",
  "description": "Client for the golusoris-owned eBPF SK_MSG sockhash; kernel-bypass colocated IPC for SvelteKit ↔ Golusoris. Linux + cgroup v2 + kernel >=5.10 only.",
  "type": "module",
  "private": false,
  "sideEffects": false,
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "engines": {
    "node": ">=24"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "keywords": [
    "sveltesentio",
    "ebpf",
    "sockmap",
    "ipc",
    "golusoris",
    "colocated"
  ],
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "src",
    "CHANGELOG.md"
  ]
}
