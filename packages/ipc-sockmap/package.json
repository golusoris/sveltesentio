{
  "name": "@sveltesentio/ipc-sockmap",
  "version": "0.1.0",
  "description": "Colocated-IPC client for SvelteKit ↔ Golusoris: AF_UNIX (Tier 1) + length-prefixed framing + transport-ladder detection + eBPF SK_MSG sockhash (Tier 3) observe/handoff client — capability probe, systemd socket-activation, key-count/Prometheus observability, degrades to Tier 1. Node + Linux.",
  "type": "module",
  "private": false,
  "sideEffects": false,
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    },
    "./transport": {
      "import": "./src/transport.ts",
      "types": "./src/transport.ts"
    },
    "./client": {
      "import": "./src/client.ts",
      "types": "./src/client.ts"
    },
    "./sockmap": {
      "import": "./src/sockmap.ts",
      "types": "./src/sockmap.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --coverage"
  },
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "@sveltesentio/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "keywords": [
    "sveltesentio",
    "ipc",
    "af_unix",
    "ebpf",
    "sockmap",
    "golusoris",
    "colocated"
  ],
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "src",
    "CHANGELOG.md"
  ]
}
