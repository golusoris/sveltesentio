{
  "name": "@sveltesentio/auth",
  "version": "0.3.0",
  "description": "OIDC PKCE flow + code exchange + handleCsrf hook + passkey wrappers + CSRF HMAC double-submit + session cookie options + permissions (Web Crypto; server-only orchestration)",
  "type": "module",
  "private": false,
  "sideEffects": false,
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    },
    "./csrf": {
      "import": "./src/csrf.ts",
      "types": "./src/csrf.ts"
    },
    "./cookies": {
      "import": "./src/cookies.ts",
      "types": "./src/cookies.ts"
    },
    "./pkce": {
      "import": "./src/pkce.ts",
      "types": "./src/pkce.ts"
    },
    "./random": {
      "import": "./src/random.ts",
      "types": "./src/random.ts"
    },
    "./permissions": {
      "import": "./src/permissions.ts",
      "types": "./src/permissions.ts"
    },
    "./oidc": {
      "import": "./src/oidc.ts",
      "types": "./src/oidc.ts"
    },
    "./csrf-hook": {
      "import": "./src/csrf-hook.ts",
      "types": "./src/csrf-hook.ts"
    },
    "./mfa": {
      "import": "./src/mfa.ts",
      "types": "./src/mfa.ts"
    },
    "./passkey": {
      "import": "./src/passkey.ts",
      "types": "./src/passkey.ts"
    },
    "./use-permissions": {
      "import": "./src/use-permissions.svelte.ts",
      "types": "./src/use-permissions.svelte.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "peerDependencies": {
    "@simplewebauthn/browser": ">=13.0.0",
    "@sveltejs/kit": ">=2.0.0",
    "@sveltesentio/core": "workspace:*",
    "svelte": ">=5.0.0",
    "zod": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "@simplewebauthn/browser": {
      "optional": true
    }
  },
  "devDependencies": {
    "@sveltejs/kit": "^2.0.0",
    "@sveltesentio/core": "workspace:*",
    "svelte": "^5.55.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4",
    "zod": "^4.3.6"
  },
  "keywords": [
    "sveltesentio",
    "auth",
    "oidc",
    "pkce",
    "csrf",
    "session",
    "permissions",
    "webauthn"
  ],
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "src",
    "CHANGELOG.md"
  ]
}
