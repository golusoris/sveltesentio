{
  "extends": "../../../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "moduleResolution": "bundler",
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": false
  },
  "include": [
    "tests/**/*.ts",
    "harness/**/*.ts",
    "harness/**/*.svelte",
    "vite.config.ts",
    "playwright.config.ts"
  ],
  "exclude": ["dist"]
}
