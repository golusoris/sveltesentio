{
  "name": "@sveltesentio/ui",
  "version": "0.5.0",
  "description": "shadcn-svelte CLI wrapper, Tailwind 4 preset, design tokens per interface type",
  "type": "module",
  "private": false,
  "sideEffects": false,
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    },
    "./presets": {
      "import": "./src/presets/index.ts",
      "types": "./src/presets/index.ts"
    },
    "./tokens": {
      "import": "./src/tokens/index.ts",
      "types": "./src/tokens/index.ts"
    },
    "./button": {
      "import": "./src/button/index.ts",
      "types": "./src/button/index.ts"
    },
    "./button/component": {
      "svelte": "./src/button/Button.svelte",
      "default": "./src/button/Button.svelte"
    },
    "./input": {
      "import": "./src/input/index.ts",
      "types": "./src/input/index.ts"
    },
    "./input/component": {
      "svelte": "./src/input/Input.svelte",
      "default": "./src/input/Input.svelte"
    },
    "./dialog": {
      "import": "./src/dialog/index.ts",
      "types": "./src/dialog/index.ts"
    },
    "./dialog/component": {
      "svelte": "./src/dialog/Dialog.svelte",
      "default": "./src/dialog/Dialog.svelte"
    },
    "./theme-toggle": {
      "import": "./src/theme/toggle.ts",
      "types": "./src/theme/toggle.ts"
    },
    "./theme-toggle/component": {
      "svelte": "./src/theme/ThemeToggle.svelte",
      "default": "./src/theme/ThemeToggle.svelte"
    },
    "./theme-customizer": {
      "import": "./src/theme/customizer-export.ts",
      "types": "./src/theme/customizer-export.ts"
    },
    "./theme-customizer/component": {
      "svelte": "./src/theme/ThemeCustomizer.svelte",
      "default": "./src/theme/ThemeCustomizer.svelte"
    },
    "./font-preset": {
      "import": "./src/font/index.ts",
      "types": "./src/font/index.ts"
    },
    "./toast": {
      "import": "./src/toast/index.ts",
      "types": "./src/toast/index.ts"
    },
    "./data": {
      "import": "./src/data/index.ts",
      "types": "./src/data/index.ts"
    },
    "./data/store": {
      "import": "./src/data/createDataTable.svelte.ts",
      "types": "./src/data/createDataTable.svelte.ts"
    },
    "./data/table": {
      "svelte": "./src/data/DataTable.svelte",
      "default": "./src/data/DataTable.svelte"
    },
    "./data/virtual-list": {
      "svelte": "./src/data/VirtualList.svelte",
      "default": "./src/data/VirtualList.svelte"
    },
    "./cmd": {
      "import": "./src/cmd/index.ts",
      "types": "./src/cmd/index.ts"
    },
    "./cmd/palette": {
      "svelte": "./src/cmd/CommandPalette.svelte",
      "default": "./src/cmd/CommandPalette.svelte"
    },
    "./markdown": {
      "import": "./src/markdown/index.ts",
      "types": "./src/markdown/index.ts"
    },
    "./markdown/component": {
      "svelte": "./src/markdown/Markdown.svelte",
      "default": "./src/markdown/Markdown.svelte"
    },
    "./icons": {
      "import": "./src/icons/index.ts",
      "types": "./src/icons/index.ts"
    },
    "./icons/component": {
      "svelte": "./src/icons/Icon.svelte",
      "default": "./src/icons/Icon.svelte"
    }
  },
  "scripts": {
    "build": "tsc",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --coverage --passWithNoTests"
  },
  "dependencies": {
    "dompurify": "^3.4.8",
    "esm-env": "^1.2.2",
    "jsdom": "^29.1.1",
    "marked": "^18.0.0"
  },
  "peerDependencies": {
    "@iconify/svelte": ">=5.0.0",
    "@lucide/svelte": ">=1.0.0",
    "@tanstack/svelte-virtual": ">=3.0.0",
    "bits-ui": ">=2.16.3",
    "mode-watcher": ">=1.1.0 <2",
    "svelte": ">=5.0.0",
    "svelte-sonner": ">=1.0.0 <2",
    "tailwindcss": ">=4.0.0",
    "tinykeys": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "@iconify/svelte": {
      "optional": true
    },
    "@lucide/svelte": {
      "optional": true
    },
    "mode-watcher": {
      "optional": true
    },
    "svelte-sonner": {
      "optional": true
    },
    "@tanstack/svelte-virtual": {
      "optional": true
    },
    "bits-ui": {
      "optional": true
    },
    "tinykeys": {
      "optional": true
    }
  },
  "devDependencies": {
    "@lucide/svelte": "^1.18.0",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@sveltesentio/testing": "workspace:*",
    "@testing-library/jest-dom": "^6.9.1",
    "@storybook/addon-svelte-csf": "5.1.2",
    "@testing-library/svelte": "^5.3.1",
    "@types/jsdom": "^28.0.3",
    "axe-core": "^4.12.1",
    "jsdom": "^29.1.1",
    "svelte": "^5.56.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "keywords": [
    "sveltesentio",
    "ui",
    "shadcn",
    "tailwind",
    "design-tokens"
  ],
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "src",
    "CHANGELOG.md",
    "!src/**/*.stories.svelte"
  ]
}
