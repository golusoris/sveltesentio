{
  "name": "@sveltesentio/media",
  "version": "0.2.0",
  "description": "Headless media player model (HLS rendition picking, media-session, play/pause/quality machine, BYO hls.js seam) + responsive-image srcset/sizes builders",
  "type": "module",
  "private": false,
  "sideEffects": false,
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    },
    "./player": {
      "import": "./src/player.ts",
      "types": "./src/player.ts"
    },
    "./image": {
      "import": "./src/image.ts",
      "types": "./src/image.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "peerDependencies": {
    "hls.js": ">=1.6.0"
  },
  "peerDependenciesMeta": {
    "hls.js": {
      "optional": true
    }
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  },
  "keywords": [
    "sveltesentio",
    "media",
    "hls",
    "srcset",
    "media-session",
    "10-foot-ui"
  ],
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "src",
    "CHANGELOG.md"
  ]
}
