{
  "name": "@sveltesentio/shell",
  "version": "0.2.0",
  "description": "Device-class layout + input primitives — classifyDevice, D-pad/Gamepad focus graph, Tailwind 4 safe-area, optional @vite-pwa/sveltekit registration",
  "type": "module",
  "private": false,
  "sideEffects": false,
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    },
    "./device-class": {
      "import": "./src/device-class.ts",
      "types": "./src/device-class.ts"
    },
    "./dpad": {
      "import": "./src/dpad-index.ts",
      "types": "./src/dpad-index.ts"
    },
    "./safe-area": {
      "import": "./src/safe-area.ts",
      "types": "./src/safe-area.ts"
    },
    "./pwa": {
      "import": "./src/pwa.ts",
      "types": "./src/pwa.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --coverage",
    "test:e2e": "playwright test --config e2e/playwright.config.ts"
  },
  "peerDependencies": {
    "@sveltejs/kit": ">=2.0.0",
    "@vite-pwa/sveltekit": ">=1.1.0",
    "svelte": ">=5.0.0",
    "vite-plugin-pwa": ">=1.2.0"
  },
  "peerDependenciesMeta": {
    "@sveltejs/kit": {
      "optional": true
    },
    "@vite-pwa/sveltekit": {
      "optional": true
    },
    "vite-plugin-pwa": {
      "optional": true
    }
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@playwright/test": "^1.61.0",
    "@sveltesentio/testing": "workspace:*",
    "@types/node": "^24.13.2",
    "svelte": "^5.56.3",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  },
  "keywords": [
    "sveltesentio",
    "shell",
    "device-class",
    "pwa",
    "10-foot",
    "handheld",
    "d-pad",
    "gamepad",
    "safe-area"
  ],
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "src",
    "CHANGELOG.md"
  ]
}
