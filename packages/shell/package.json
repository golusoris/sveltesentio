{
  "name": "@sveltesentio/shell",
  "version": "0.0.1",
  "description": "Device-class layout primitives + PWA (@vite-pwa/sveltekit) + Tailwind 4 safe-area + D-pad focus graph",
  "type": "module",
  "private": false,
  "sideEffects": false,
  "exports": {
    ".": { "import": "./src/index.ts", "types": "./src/index.ts" },
    "./pwa": { "import": "./src/pwa/index.ts", "types": "./src/pwa/index.ts" },
    "./layout": { "import": "./src/layout/index.ts", "types": "./src/layout/index.ts" },
    "./dpad": { "import": "./src/dpad/index.ts", "types": "./src/dpad/index.ts" }
  },
  "scripts": {
    "build": "tsc",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "peerDependencies": {
    "svelte": ">=5.0.0",
    "@sveltejs/kit": ">=2.0.0",
    "@vite-pwa/sveltekit": ">=1.1.0",
    "vite-plugin-pwa": ">=1.2.0"
  },
  "devDependencies": {
    "svelte": "^5.55.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  },
  "keywords": ["sveltesentio", "shell", "pwa", "10-foot", "handheld", "d-pad", "safe-area"]
}
