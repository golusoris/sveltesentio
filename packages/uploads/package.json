{
  "name": "@sveltesentio/uploads",
  "version": "0.1.0",
  "description": "Resumable uploads — tus-js-client + exifr (EXIF strip) + file-type (magic-byte sniffing)",
  "type": "module",
  "private": false,
  "sideEffects": false,
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    },
    "./validate": {
      "import": "./src/validate.ts",
      "types": "./src/validate.ts"
    },
    "./exif": {
      "import": "./src/exif.ts",
      "types": "./src/exif.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "peerDependencies": {
    "tus-js-client": ">=4.3.0"
  },
  "devDependencies": {
    "tus-js-client": "^4.3.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "keywords": [
    "sveltesentio",
    "uploads",
    "tus",
    "exifr",
    "file-type",
    "resumable"
  ],
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "src",
    "CHANGELOG.md"
  ],
  "dependencies": {
    "exifr": "^7.1.3",
    "file-type": "^22.0.1"
  },
  "peerDependenciesMeta": {
    "tus-js-client": {
      "optional": true
    }
  }
}
