{
  "name": "@sveltesentio/collab",
  "version": "0.3.0",
  "description": "Yjs CRDT + y-websocket provider + createYjsStore / createYjsMap rune helpers + awareness/presence helpers",
  "type": "module",
  "private": false,
  "sideEffects": false,
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    },
    "./array": {
      "import": "./src/yjs-array.ts",
      "types": "./src/yjs-array.ts"
    },
    "./map": {
      "import": "./src/yjs-map.ts",
      "types": "./src/yjs-map.ts"
    },
    "./text": {
      "import": "./src/yjs-text.ts",
      "types": "./src/yjs-text.ts"
    },
    "./provider": {
      "import": "./src/provider.ts",
      "types": "./src/provider.ts"
    },
    "./store": {
      "import": "./src/createYjsStore.svelte.ts",
      "types": "./src/createYjsStore.svelte.ts"
    },
    "./map-store": {
      "import": "./src/createYjsMap.svelte.ts",
      "types": "./src/createYjsMap.svelte.ts"
    },
    "./text-store": {
      "import": "./src/createYjsText.svelte.ts",
      "types": "./src/createYjsText.svelte.ts"
    },
    "./awareness": {
      "import": "./src/awareness.ts",
      "types": "./src/awareness.ts"
    },
    "./presence-store": {
      "import": "./src/presence-store.svelte.ts",
      "types": "./src/presence-store.svelte.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "peerDependencies": {
    "svelte": ">=5.0.0",
    "y-protocols": ">=1.0.5",
    "y-websocket": ">=2.0.0",
    "yjs": ">=13.6.0"
  },
  "peerDependenciesMeta": {
    "y-protocols": {
      "optional": true
    }
  },
  "devDependencies": {
    "svelte": "^5.56.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "keywords": [
    "sveltesentio",
    "yjs",
    "crdt",
    "collaboration",
    "y-websocket",
    "awareness",
    "presence"
  ],
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "src",
    "CHANGELOG.md"
  ]
}
