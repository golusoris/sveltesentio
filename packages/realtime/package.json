{
  "name": "@sveltesentio/realtime",
  "version": "0.0.1",
  "description": "Native SSE client with exponential backoff + buffered emitter (ConnectRPC + Yjs WS follow-through)",
  "type": "module",
  "private": false,
  "sideEffects": false,
  "exports": {
    ".": { "import": "./src/index.ts", "types": "./src/index.ts" },
    "./sse": { "import": "./src/sse-client.ts", "types": "./src/sse-client.ts" },
    "./backoff": { "import": "./src/backoff.ts", "types": "./src/backoff.ts" },
    "./buffered-emitter": {
      "import": "./src/buffered-emitter.ts",
      "types": "./src/buffered-emitter.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "peerDependencies": {
    "@connectrpc/connect": ">=2.0.0",
    "@sveltejs/kit": ">=2.0.0",
    "svelte": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "@connectrpc/connect": { "optional": true }
  },
  "devDependencies": {
    "@sveltejs/kit": "^2.0.0",
    "svelte": "^5.55.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  },
  "keywords": ["sveltesentio", "realtime", "sse", "websocket", "connectrpc", "grpc"]
}
