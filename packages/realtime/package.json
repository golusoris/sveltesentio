{
  "name": "@sveltesentio/realtime",
  "version": "0.4.0",
  "description": "Native SSE client with exponential backoff + buffered emitter (ConnectRPC + Yjs WS follow-through)",
  "type": "module",
  "private": false,
  "sideEffects": false,
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    },
    "./sse": {
      "import": "./src/sse-client.ts",
      "types": "./src/sse-client.ts"
    },
    "./backoff": {
      "import": "./src/backoff.ts",
      "types": "./src/backoff.ts"
    },
    "./buffered-emitter": {
      "import": "./src/buffered-emitter.ts",
      "types": "./src/buffered-emitter.ts"
    },
    "./use-sse": {
      "svelte": "./src/use-sse.svelte.ts",
      "import": "./src/use-sse.svelte.ts",
      "types": "./src/use-sse.svelte.ts"
    },
    "./connect-stream": {
      "import": "./src/connect-stream.ts",
      "types": "./src/connect-stream.ts"
    },
    "./use-connect-stream": {
      "svelte": "./src/use-connect-stream.svelte.ts",
      "import": "./src/use-connect-stream.svelte.ts",
      "types": "./src/use-connect-stream.svelte.ts"
    },
    "./rpc": {
      "svelte": "./src/rpc/index.ts",
      "import": "./src/rpc/index.ts",
      "types": "./src/rpc/index.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "peerDependencies": {
    "@bufbuild/protobuf": ">=2.0.0",
    "@connectrpc/connect": ">=2.0.0",
    "@connectrpc/connect-web": ">=2.0.0",
    "@sveltejs/kit": ">=2.0.0",
    "@sveltesentio/core": "workspace:*",
    "svelte": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "@bufbuild/protobuf": {
      "optional": true
    },
    "@connectrpc/connect": {
      "optional": true
    },
    "@connectrpc/connect-web": {
      "optional": true
    },
    "@sveltesentio/core": {
      "optional": true
    }
  },
  "devDependencies": {
    "@bufbuild/protobuf": "^2.11.0",
    "@connectrpc/connect": "^2.1.2",
    "@connectrpc/connect-web": "^2.1.2",
    "@sveltejs/kit": "^2.65.1",
    "@sveltesentio/core": "workspace:*",
    "svelte": "^5.56.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "keywords": [
    "sveltesentio",
    "realtime",
    "sse",
    "websocket",
    "connectrpc",
    "grpc"
  ],
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "src",
    "CHANGELOG.md"
  ]
}
