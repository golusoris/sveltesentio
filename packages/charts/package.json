{
  "name": "@sveltesentio/charts",
  "version": "0.4.0",
  "description": "Thin LayerChart wrappers with a WCAG 2.2 AA accessibility envelope (ChartFigure) and dashboard presets",
  "type": "module",
  "private": false,
  "sideEffects": false,
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    },
    "./figure": {
      "svelte": "./src/ChartFigure.svelte",
      "default": "./src/ChartFigure.svelte"
    },
    "./a11y-table": {
      "import": "./src/a11y-table.ts",
      "types": "./src/a11y-table.ts"
    },
    "./preset": {
      "import": "./src/preset.ts",
      "types": "./src/preset.ts"
    },
    "./palette": {
      "import": "./src/palette.ts",
      "types": "./src/palette.ts"
    },
    "./chart-series": {
      "import": "./src/chart-series.ts",
      "types": "./src/chart-series.ts"
    },
    "./chart": {
      "svelte": "./src/Chart.svelte",
      "default": "./src/Chart.svelte"
    },
    "./line": {
      "svelte": "./src/LineChart.svelte",
      "default": "./src/LineChart.svelte"
    },
    "./area": {
      "svelte": "./src/AreaChart.svelte",
      "default": "./src/AreaChart.svelte"
    },
    "./bar": {
      "svelte": "./src/BarChart.svelte",
      "default": "./src/BarChart.svelte"
    },
    "./pie": {
      "svelte": "./src/PieChart.svelte",
      "default": "./src/PieChart.svelte"
    },
    "./scatter": {
      "svelte": "./src/ScatterChart.svelte",
      "default": "./src/ScatterChart.svelte"
    }
  },
  "scripts": {
    "build": "tsc",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --coverage"
  },
  "peerDependencies": {
    "layerchart": ">=2.0.0-next.43",
    "svelte": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "layerchart": {
      "optional": true
    }
  },
  "devDependencies": {
    "@storybook/addon-svelte-csf": "5.1.2",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.3.1",
    "axe-core": "^4.12.1",
    "jsdom": "^29.1.1",
    "layerchart": "2.0.0-next.65",
    "svelte": "^5.56.3",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  },
  "keywords": [
    "sveltesentio",
    "charts",
    "layerchart",
    "dashboard",
    "accessibility",
    "data-visualization"
  ],
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "src",
    "CHANGELOG.md",
    "!src/**/*.stories.svelte"
  ]
}
