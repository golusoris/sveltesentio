{
  "name": "@sveltesentio/flow",
  "version": "0.3.0",
  "description": "@xyflow/svelte wrappers — node editors, DAG helpers, canvas utilities",
  "type": "module",
  "private": false,
  "sideEffects": false,
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    },
    "./dag": {
      "import": "./src/dag.ts",
      "types": "./src/dag.ts"
    },
    "./layout": {
      "import": "./src/layout.ts",
      "types": "./src/layout.ts"
    },
    "./layout-worker": {
      "import": "./src/layout-worker.ts",
      "types": "./src/layout-worker.ts"
    },
    "./node-palette": {
      "import": "./src/node-palette.ts",
      "types": "./src/node-palette.ts"
    },
    "./canvas": {
      "svelte": "./src/FlowCanvas.svelte",
      "types": "./src/canvas.ts",
      "import": "./src/canvas.ts"
    },
    "./canvas-model": {
      "import": "./src/canvas-model.ts",
      "types": "./src/canvas-model.ts"
    },
    "./nodes": {
      "import": "./src/nodes.ts",
      "types": "./src/nodes.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --coverage"
  },
  "dependencies": {
    "@sveltesentio/core": "workspace:*"
  },
  "peerDependencies": {
    "@xyflow/svelte": ">=1.0.0",
    "elkjs": ">=0.11.0",
    "svelte": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "@xyflow/svelte": {
      "optional": true
    }
  },
  "devDependencies": {
    "@storybook/addon-svelte-csf": "5.1.2",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@sveltesentio/testing": "workspace:*",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.3.1",
    "@xyflow/svelte": "^1.6.0",
    "axe-core": "^4.12.1",
    "elkjs": "^0.11.0",
    "jsdom": "^29.1.1",
    "svelte": "^5.56.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "keywords": [
    "sveltesentio",
    "flow",
    "node-editor",
    "dag",
    "xyflow"
  ],
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "src",
    "CHANGELOG.md",
    "!src/**/*.stories.svelte"
  ]
}
