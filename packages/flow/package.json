{
  "name": "@sveltesentio/flow",
  "version": "0.2.0",
  "description": "@xyflow/svelte wrappers — node editors, DAG helpers, canvas utilities",
  "type": "module",
  "private": false,
  "sideEffects": false,
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    },
    "./dag": {
      "import": "./src/dag.ts",
      "types": "./src/dag.ts"
    },
    "./layout": {
      "import": "./src/layout.ts",
      "types": "./src/layout.ts"
    },
    "./node-palette": {
      "import": "./src/node-palette.ts",
      "types": "./src/node-palette.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "peerDependencies": {
    "@xyflow/svelte": ">=1.0.0",
    "elkjs": ">=0.9.0",
    "svelte": ">=5.0.0"
  },
  "devDependencies": {
    "elkjs": "^0.11.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  },
  "keywords": [
    "sveltesentio",
    "flow",
    "node-editor",
    "dag",
    "xyflow"
  ],
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "src",
    "CHANGELOG.md"
  ]
}
