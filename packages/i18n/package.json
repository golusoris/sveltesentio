{
  "name": "@sveltesentio/i18n",
  "version": "0.0.1",
  "description": "Paraglide-js v2 wrappers — locale detection, Intl formatters, a11y announcer, RTL direction",
  "type": "module",
  "private": false,
  "sideEffects": false,
  "exports": {
    ".": { "import": "./src/index.ts", "types": "./src/index.ts" },
    "./direction": { "import": "./src/direction.ts", "types": "./src/direction.ts" },
    "./intl": { "import": "./src/intl.ts", "types": "./src/intl.ts" },
    "./announcer": { "import": "./src/announcer.ts", "types": "./src/announcer.ts" }
  },
  "scripts": {
    "build": "tsc",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "peerDependencies": {
    "@inlang/paraglide-js": ">=2.0.0",
    "@sveltejs/kit": ">=2.0.0",
    "svelte": ">=5.0.0"
  },
  "devDependencies": {
    "@inlang/paraglide-js": "^2.15.3",
    "@sveltejs/kit": "^2.0.0",
    "jsdom": "^27.0.0",
    "svelte": "^5.55.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  },
  "keywords": ["sveltesentio", "i18n", "paraglide", "localization", "rtl", "a11y"]
}
