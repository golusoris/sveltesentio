{
  "name": "@sveltesentio/i18n",
  "version": "0.3.0",
  "description": "Paraglide-js v2 wrappers — locale detection, Intl formatters, a11y announcer, RTL direction",
  "type": "module",
  "private": false,
  "sideEffects": false,
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    },
    "./direction": {
      "import": "./src/direction.ts",
      "types": "./src/direction.ts"
    },
    "./intl": {
      "import": "./src/intl.ts",
      "types": "./src/intl.ts"
    },
    "./announcer": {
      "import": "./src/announcer.ts",
      "types": "./src/announcer.ts"
    },
    "./load-locale-font": {
      "import": "./src/load-locale-font.ts",
      "types": "./src/load-locale-font.ts"
    },
    "./lang-sync": {
      "svelte": "./src/LangSync.svelte",
      "default": "./src/LangSync.svelte"
    },
    "./locale-switcher": {
      "svelte": "./src/LocaleSwitcher.svelte",
      "default": "./src/LocaleSwitcher.svelte"
    }
  },
  "scripts": {
    "build": "tsc",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "peerDependencies": {
    "@inlang/paraglide-js": ">=2.0.0",
    "@sveltejs/kit": ">=2.0.0",
    "svelte": ">=5.0.0"
  },
  "devDependencies": {
    "@inlang/paraglide-js": "^2.19.0",
    "@sveltejs/kit": "^2.65.1",
    "jsdom": "^29.0.0",
    "svelte": "^5.56.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "keywords": [
    "sveltesentio",
    "i18n",
    "paraglide",
    "localization",
    "rtl",
    "a11y"
  ],
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "src",
    "CHANGELOG.md"
  ]
}
