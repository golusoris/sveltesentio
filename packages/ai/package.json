{
  "name": "@sveltesentio/ai",
  "version": "0.3.0",
  "description": "Server-proxy-only LLM client, on-device transformers seam, and EU AI Act audit hook for SvelteKit",
  "type": "module",
  "private": false,
  "sideEffects": false,
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    },
    "./audit": {
      "import": "./src/audit.ts",
      "types": "./src/audit.ts"
    },
    "./proxy": {
      "import": "./src/proxy.ts",
      "types": "./src/proxy.ts"
    },
    "./edge": {
      "import": "./src/edge.ts",
      "types": "./src/edge.ts"
    },
    "./server": {
      "import": "./src/server.ts",
      "types": "./src/server.ts"
    },
    "./client": {
      "import": "./src/client.svelte.ts",
      "types": "./src/client.svelte.ts"
    },
    "./client/component": {
      "svelte": "./src/ChatStream.svelte",
      "default": "./src/ChatStream.svelte"
    }
  },
  "scripts": {
    "build": "tsc",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --coverage"
  },
  "dependencies": {
    "@sveltesentio/core": "workspace:*"
  },
  "peerDependencies": {
    "@anthropic-ai/sdk": ">=0.40.0",
    "@huggingface/transformers": ">=4.1.0",
    "@sveltejs/kit": ">=2.0.0",
    "ollama": ">=0.5.0",
    "svelte": ">=5.0.0",
    "zod": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "@anthropic-ai/sdk": {
      "optional": true
    },
    "@huggingface/transformers": {
      "optional": true
    },
    "ollama": {
      "optional": true
    }
  },
  "devDependencies": {
    "@sveltejs/kit": "^2.65.1",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@sveltesentio/core": "workspace:*",
    "@sveltesentio/testing": "workspace:*",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.3.1",
    "axe-core": "^4.12.1",
    "jsdom": "^29.1.1",
    "svelte": "^5.56.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8",
    "zod": "^4.4.3"
  },
  "keywords": [
    "sveltesentio",
    "ai",
    "llm",
    "anthropic",
    "ollama",
    "transformers",
    "edge-ai",
    "eu-ai-act",
    "audit",
    "rfc9457"
  ],
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "src",
    "CHANGELOG.md"
  ]
}
