{
  "name": "@sveltesentio/ai",
  "version": "0.1.0",
  "description": "LLM chat components, edge AI (Transformers.js/WebGPU), semantic search utilities",
  "type": "module",
  "private": false,
  "sideEffects": false,
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "peerDependencies": {
    "svelte": ">=5.0.0",
    "@sveltejs/kit": ">=2.0.0",
    "@huggingface/transformers": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "@huggingface/transformers": {
      "optional": true
    }
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  },
  "keywords": [
    "sveltesentio",
    "ai",
    "llm",
    "transformers",
    "edge-ai",
    "semantic-search"
  ]
}
