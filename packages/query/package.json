{
  "name": "@sveltesentio/query",
  "version": "0.1.0",
  "description": "TanStack Query wrappers for SvelteKit — load helpers, optimistic updates, SSR hydration",
  "type": "module",
  "private": false,
  "sideEffects": false,
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "peerDependencies": {
    "@tanstack/svelte-query": ">=6.0.0",
    "svelte": ">=5.0.0",
    "@sveltejs/kit": ">=2.0.0"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  },
  "keywords": [
    "sveltesentio",
    "tanstack-query",
    "sveltekit",
    "data-fetching"
  ],
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "src",
    "CHANGELOG.md"
  ]
}
