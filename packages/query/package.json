{
  "name": "@sveltesentio/query",
  "version": "0.3.0",
  "description": "TanStack Query wrappers for SvelteKit — load helpers, optimistic updates, SSR hydration",
  "type": "module",
  "private": false,
  "sideEffects": false,
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    },
    "./query-client": {
      "import": "./src/query-client.ts",
      "types": "./src/query-client.ts"
    },
    "./query": {
      "import": "./src/query.ts",
      "types": "./src/query.ts"
    },
    "./hydration": {
      "import": "./src/hydration.ts",
      "types": "./src/hydration.ts"
    },
    "./infinite": {
      "import": "./src/infinite.ts",
      "types": "./src/infinite.ts"
    },
    "./mutation": {
      "import": "./src/mutation.ts",
      "types": "./src/mutation.ts"
    },
    "./connect": {
      "import": "./src/connect-query.ts",
      "types": "./src/connect-query.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --coverage"
  },
  "peerDependencies": {
    "@bufbuild/protobuf": ">=2.0.0",
    "@connectrpc/connect": ">=2.0.0",
    "@sveltejs/kit": ">=2.0.0",
    "@tanstack/svelte-query": ">=6.0.0",
    "svelte": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "@bufbuild/protobuf": {
      "optional": true
    },
    "@connectrpc/connect": {
      "optional": true
    }
  },
  "devDependencies": {
    "@bufbuild/protobuf": "^2.11.0",
    "@connectrpc/connect": "^2.1.2",
    "@tanstack/svelte-query": "^6.1.34",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "keywords": [
    "sveltesentio",
    "tanstack-query",
    "sveltekit",
    "data-fetching"
  ],
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "src",
    "CHANGELOG.md"
  ],
  "dependencies": {
    "@sveltesentio/core": "workspace:*"
  }
}
