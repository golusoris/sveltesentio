{
  "name": "@sveltesentio/forms",
  "version": "0.0.1",
  "description": "Superforms + Zod form patterns, field components, action helpers",
  "type": "module",
  "private": false,
  "sideEffects": false,
  "exports": {
    ".": { "import": "./src/index.ts", "types": "./src/index.ts" }
