{
  "name": "@sveltesentio/forms",
  "version": "0.2.0",
  "description": "Superforms v2 + Zod v4 thin wrapper with RFC 9457 field-error mapping",
  "type": "module",
  "private": false,
  "sideEffects": false,
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    },
    "./problem": {
      "import": "./src/problem-to-field-errors.ts",
      "types": "./src/problem-to-field-errors.ts"
    },
    "./server": {
      "import": "./src/server.ts",
      "types": "./src/server.ts"
    },
    "./action": {
      "import": "./src/form-action.ts",
      "types": "./src/form-action.ts"
    },
    "./formsnap": {
      "svelte": "./src/formsnap.ts",
      "import": "./src/formsnap.ts",
      "types": "./src/formsnap.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "peerDependencies": {
    "@sveltejs/kit": ">=2.0.0",
    "@sveltesentio/core": "workspace:*",
    "formsnap": ">=2.0.0",
    "svelte": ">=5.0.0",
    "sveltekit-superforms": ">=2.0.0",
    "zod": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "formsnap": {
      "optional": true
    }
  },
  "devDependencies": {
    "@sveltejs/kit": "^2.0.0",
    "@sveltesentio/core": "workspace:*",
    "svelte": "^5.55.4",
    "sveltekit-superforms": "^2.30.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4",
    "zod": "^4.3.6"
  },
  "keywords": [
    "sveltesentio",
    "forms",
    "superforms",
    "zod",
    "validation",
    "rfc9457"
  ],
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "src",
    "CHANGELOG.md"
  ]
}
