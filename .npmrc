# pnpm 11 aborts install with ERR_PNPM_IGNORED_BUILDS when a dependency has an
# un-approved build script. esbuild / sharp / onnxruntime-node / protobufjs ship
# prebuilt platform binaries — their postinstalls are not needed for the
# src/-only package publish or the test suite (CI is green with them ignored),
# and NOT executing transitive dependency build scripts is the supply-chain-safer
# default (§2.5). This downgrades the abort to a warning so install succeeds in
# CI as it does locally.
strict-dep-builds=false
