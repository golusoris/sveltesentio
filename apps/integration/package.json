{
	"name": "@sveltesentio/integration",
	"version": "0.0.0",
	"description": "Private integration-consumer that proves the @sveltesentio/* packages compose and typecheck together (verification artifact, not a deployable app)",
	"type": "module",
	"private": true,
	"scripts": {
		"typecheck": "tsc --noEmit",
		"lint": "eslint src/ test/",
		"test": "vitest run"
	},
	"dependencies": {
		"@sveltesentio/api": "workspace:*",
		"@sveltesentio/auth": "workspace:*",
		"@sveltesentio/core": "workspace:*",
		"@sveltesentio/forms": "workspace:*",
		"@sveltesentio/query": "workspace:*",
		"@sveltesentio/realtime": "workspace:*",
		"@sveltesentio/ui": "workspace:*"
	},
	"devDependencies": {
		"@sveltejs/kit": "^2.65.2",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tanstack/svelte-query": "^6.1.34",
		"openapi-fetch": "^0.17.0",
		"svelte": "^5.56.3",
		"sveltekit-superforms": "^2.30.1",
		"typescript": "^6.0.3",
		"vitest": "^4.1.9",
		"zod": "^4.4.3"
	}
}
